{
  "outputDirectory": "build/client",
  "buildCommand": "react-router build",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "farmaciashoy.cl" }],
      "destination": "https://www.farmaciashoy.cl/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/__spa-fallback.html" }
  ]
}